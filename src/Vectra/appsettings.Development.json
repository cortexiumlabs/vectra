{
  "System": {
    "Server": {
      "Http": {
        "Port": 7080
      }
    },
    "Storage": {
      "Database": {
        "Provider": "Sqlite",
        "Postgres": {
          "ConnectionString": "Host=localhost;Database=mydb;Username=user;Password=pass"
        },
        "Sqlite": {
          "ConnectionString": "Data Source=vectra.db"
        }
      },
      "Cache": {
        "Provider": "Redis",
        "Redis": {
          "Address": "localhost:6379",
          "TimeToLiveMilliseconds": 86400000
        },
        "Memory": {
          "TimeToLiveMilliseconds": 86400000
        }
      }
    }
  },
  "Observability": {
    "Logging": {
      "File": {
        "Enabled": true,
        "LogPath": "logs/log-.txt",
        "RollingInterval": "Day",
        "MinimumLevel": "Warning"
      },
      "Seq": {
        "Enabled": false,
        "ServerUrl": "http://localhost:5341",
        "MinimumLevel": "Information"
      }
    }
  },
  "Security": {
    "AgentAuth": {
      "Provider": "SelfSigned",
      "Issuer": "vectra",
      "Audience": "vectra-agents",
      "ExpirationMinutes": 15
    }
  },
  "Features": {
    "HITL": {
      "Provider": "Memory"
    },
    "Policy": {
      "Directory": "vectra_policies/"
    }
  }
}