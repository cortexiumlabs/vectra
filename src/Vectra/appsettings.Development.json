{
  "System": {
    "Server": {
      "Http": {
        "Port": 7080
      }
    },
    "Storage": {
      "Database": {
        "DefaultProvider": "Sqlite",
        "Providers": {
          "Postgres": {
            "ConnectionString": "Host=localhost;Database=mydb;Username=user;Password=pass"
          },
          "Sqlite": {
            "ConnectionString": "Data Source=vectra.db"
          }
        }
      },
      "Cache": {
        "DefaultProvider": "Memory",
        "Providers": {
          "Redis": {
            "Address": "localhost:6379",
            "TimeToLive": "1.00:00:00",
            "AbortOnConnectFail": false,
            "ConnectRetry": 5,
            "ConnectTimeout": "00:00:05"
          },
          "Memory": {
            "TimeToLive": "1.00:00:00"
          }
        }
      }
    },
    "RateLimit": {
      "Enabled": true,
      "DefaultRequestsPerMinute": 60
    },
    "CircuitBreaker": {
      "Enabled": true,
      "FailureThreshold": 5,
      "OpenDurationSeconds": 30,
      "SamplingWindowSeconds": 60
    }
  },
  "Observability": {
    "Logging": {
      "File": {
        "Enabled": true,
        "LogPath": "logs/log-.txt",
        "RollingInterval": "Day",
        "MinimumLevel": "Warning"
      },
      "Seq": {
        "Enabled": false,
        "ServerUrl": "http://localhost:5341",
        "MinimumLevel": "Information"
      }
    }
  },
  "Security": {
    "AgentAuth": {
      "Provider": "SelfSigned",
      "SelfSigned": {
        "Secret": "v3ctr@D3v$K3y!2025#Zx9Lq8Rp4Wm6T",
        "Issuer": "vectra",
        "Audience": "vectra-agents",
        "Expiration": "00:15:00"
      }
    }
  },
  "Semantic": {
    "Enabled": true,
    "ConfidenceThreshold": 0.7,
    "DefaultProvider": "Internal",
    "Providers": {
      "Internal": {
        "ModelType": "Community",
        "PackagePath": "/Models/model.zip",
        "MaxLength": 128
      },
      "Ollama": {
        "Endpoint": "http://localhost:11434",
        "Model": "llama3.2"
      },
      "AzureAi": {
        "Endpoint": "https://<your-endpoint>.inference.ai.azure.com",
        "ApiKey": "<your-api-key>",
        "Model": "gpt-4o-mini"
      },
      "OpenAi": {
        "ApiKey": "<your-openai-api-key>",
        "Model": "gpt-4o-mini"
      },
      "Gemini": {
        "ApiKey": "<your-gemini-api-key>",
        "Model": "gemini-2.0-flash"
      }
    }
  },
  "HumanInTheLoop": {
    "Enabled": true,
    "Threshold": 0.8
  },
  "Policy": {
    "Enabled": true,
    "DefaultProvider": "Internal",
    "Providers": {
      "Internal": {
        "Directory": "vectra_policies/"
      },
      "Opa": {
        "BaseUrl": "http://localhost:8181",
        "Path": "/v1/data/vectra/authz",
        "Timeout": "00:00:05"
      }
    }
  }
}